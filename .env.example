# Example environment variables for BayStays / AirBnB Manager
# Copy this to `.env` and fill real secrets in your deployment environment.

# Django
DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com

# Database (DJANGO_DATABASE_URL style). Example: postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///db.sqlite3

# Static & Media
USE_CLOUDINARY=False
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (Brevo / SMTP)
# Brevo SMTP relay (smtp-relay.brevo.com) is used by default in settings.
BREVO_SMTP_LOGIN=your-brevo-smtp-login@example.com
BREVO_SMTP_KEY=your-brevo-smtp-password-or-api-key
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL="BayStays <noreply@yourdomain.com>"

# Brevo SMS (Transactional SMS via Brevo API)
BREVO_SMS_API_KEY=your-brevo-api-key-here
BREVO_SMS_SENDER=BayStays

# M-Pesa (Lipa Na M-Pesa / B2C)
MPESA_ENV=sandbox            # sandbox or production
MPESA_SIMULATE=true         # keep true in sandbox/dev
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://yourdomain.com/bookings/payments/mpesa/callback/

# Channels / Websockets
# Provide a Redis URL for production (channels_redis). Example: redis://:password@hostname:6379/0
REDIS_URL=redis://localhost:6379/0

# Daphne / ASGI
# No secret required; Procfile runs Daphne. Use `web: daphne -b 0.0.0.0 -p $PORT airbnb_manager.asgi:application` in Procfile.

# Optional third-party services
SENTRY_DSN=

# DEBUG helpers (do not enable in production)
SERVE_STATIC=true
